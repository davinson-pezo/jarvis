# === Jarvis — variables de entorno ===
# Copia este archivo a `.env` y rellena los valores reales.
# `.env` está en .gitignore, nunca se sube al repo.

# --- Obligatorio ---
# API key de Google Gemini (gratis en https://aistudio.google.com/apikey)
GEMINI_API_KEY=tu_api_key_de_gemini_aqui

# --- Recomendado ---
# Clave para firmar cookies/sesiones del servidor web.
# Pon algo largo y aleatorio; si la dejas vacía se genera una por arranque
# (lo cual invalida las sesiones cada vez que reinicias).
FLASK_SECRET_KEY=cambia_esto_por_algo_aleatorio

# --- Opcional: voces del sistema `say` de macOS ---
# Ejecuta `say -v '?'` para ver todas las voces instaladas.
JARVIS_VOICE_ES=Jorge
JARVIS_VOICE_EN=Daniel

# --- Opcional: modelo de Gemini ---
# Por defecto gemini-2.5-flash (rápido, pensado para voz).
# Alternativas: gemini-2.5-pro (más listo, algo más lento).
# JARVIS_MODEL=gemini-2.5-flash

# --- Opcional: desactivar apertura automática del navegador (web app) ---
# Útil si ejecutas la versión web en un servidor remoto.
# JARVIS_NO_BROWSER=1
